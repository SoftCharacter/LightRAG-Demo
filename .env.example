# LightRAG Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# LLM API Keys
# =============================================================================

# OpenAI API Key (required if using OpenAI provider)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (required if using Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google Gemini API Key (required if using Gemini)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Zhipu AI API Key (required if using Zhipu)
ZHIPUAI_API_KEY=your-zhipu-api-key-here

# Jina AI API Key (required if using Jina embeddings)
JINA_API_KEY=your-jina-api-key-here

# =============================================================================
# Database Passwords & Connections
# =============================================================================

# Neo4j Database Password
NEO4J_PASSWORD=your-neo4j-password

# MongoDB Connection String (if using MongoDB)
MONGODB_URI=mongodb://username:password@localhost:27017

# PostgreSQL Connection (if using PostgreSQL)
POSTGRES_URI=postgresql://username:password@localhost:5432/lightrag

# Qdrant Vector Database URL (if using Qdrant)
# Default: http://localhost:6333 (local Qdrant instance)
QDRANT_URL=http://localhost:6333

# =============================================================================
# Web UI Configuration
# =============================================================================

# Web UI Password (if auth is enabled in config.yaml)
WEBUI_PASSWORD=your-secure-password

# =============================================================================
# Optional: Custom Configurations
# =============================================================================

# Override workspace name
# WORKSPACE=production

# Override working directory
# WORKING_DIR=./custom_storage

# Override log level
# LOG_LEVEL=DEBUG

# =============================================================================
# AWS Credentials (for Bedrock)
# =============================================================================

# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=us-east-1

